# mtg provider configuration
# Copy to .env and fill in your values

# Provider marker
PROVIDER=mtg

# Network
PORT=443

# Public endpoint (auto-detected during install)
PUBLIC_IP=203.0.113.10

# Docker
MTG_IMAGE_SOURCE=ghcr.io/9seconds/mtg:latest
MTG_IMAGE=ghcr.io/9seconds/mtg:latest

# Logging
MTG_DEBUG=info

# TLS masking
TLS_DOMAIN=www.wikipedia.org

# Access
SECRET=ee473ce5d4958eb5f968c87680a23854a0676f6f676c652e636f6d
