# mtg v2 minimal configuration
# See: https://github.com/9seconds/mtg
# Only `secret` and `bind-to` are required.

# FakeTLS secret.
# Generate one with:
#   docker run --rm ghcr.io/9seconds/mtg:latest generate-secret --hex www.google.com
secret = "ee473ce5d4958eb5f968c87680a23854a0676f6f676c652e636f6d"

# Bind address inside the container.
# The public port is controlled by Docker's published port mapping.
bind-to = "0.0.0.0:3128"

# Debug mode is boolean in mtg v2.
debug = false
