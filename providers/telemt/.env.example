# telemt provider configuration
# Copy to .env and fill in your values

# Network
PORT=443
API_PORT=9091

# Public endpoint (auto-detected during install)
PUBLIC_IP=203.0.113.10

# Provider marker
PROVIDER=telemt

# Docker
TELEMT_IMAGE_SOURCE=whn0thacked/telemt-docker:latest
TELEMT_IMAGE=whn0thacked/telemt-docker:latest

# Logging
RUST_LOG=info

# TLS masking
TLS_DOMAIN=www.wikipedia.org

# Access
PROXY_USER=main
SECRET=0123456789abcdef0123456789abcdef
