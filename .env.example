# Active provider written by the installer.
PROVIDER=telemt

# Default Telemt listener port published by Docker.
PORT=443

# Local Telemt API port, published only on 127.0.0.1.
API_PORT=9091

# Mutable update channel. `update.sh` resolves this to a pinned digest below.
TELEMT_IMAGE_SOURCE=whn0thacked/telemt-docker:latest

# Active image actually used by Docker Compose.
TELEMT_IMAGE=whn0thacked/telemt-docker:latest

# Default container log level.
RUST_LOG=info
